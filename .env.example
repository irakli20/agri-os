# Agri-OS Environment Variables

# Mapbox (for basemap tiles)
# Get your token from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Supabase (for database and authentication)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Vercel AI SDK (for generative UI)
OPENAI_API_KEY=your_openai_api_key

# Syngenta Cropwise API (for growth models and satellite data)
CROPWISE_API_KEY=your_cropwise_api_key
CROPWISE_API_URL=https://api.cropwise.com/v1
